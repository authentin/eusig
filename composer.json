{
    "name": "authentin/eusig",
    "description": "PHP library for eIDAS-compliant electronic signatures (PAdES, XAdES, CAdES)",
    "type": "library",
    "license": "MIT",
    "keywords": ["eidas", "signature", "pades", "xades", "cades", "electronic-signature", "pdf-signing"],
    "require": {
        "php": ">=8.2",
        "ext-openssl": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "php-http/mock-client": "^1.6",
        "nyholm/psr7": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "Authentin\\Eusig\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Authentin\\Eusig\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}
